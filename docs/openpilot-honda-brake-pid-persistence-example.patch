@@
+import json
+from unittest.mock import Mock
+
+from openpilot.common.params import Params
+
+
+def test_honda_brake_pid_cache_round_trip():
+  params = Params()
+  controller = Mock()
+  controller.get_persistent_state.return_value = {
+    "version": 1,
+    "carFingerprint": "HONDA_CIVIC",
+    "brakePIDFactorNonLowSpeed": 0.62,
+  }
+
+  params.put_nonblocking("HondaBrakePIDParams", json.dumps(controller.get_persistent_state()))
+  restored = json.loads(params.get("HondaBrakePIDParams"))
+
+  controller.set_persistent_state(restored)
+  controller.set_persistent_state.assert_called_once_with({
+    "version": 1,
+    "carFingerprint": "HONDA_CIVIC",
+    "brakePIDFactorNonLowSpeed": 0.62,
+  })
